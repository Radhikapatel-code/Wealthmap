# ─────────────────────────────────────────────
# WealthMap — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Google Gemini (required for CFO AI features)
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Zerodha Kite Connect (equity holdings)
# Get from: https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=   # Expires daily — regenerate via TOTP flow

# Binance (crypto holdings — use READ-ONLY API key)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CoinDCX (optional)
COINDCX_API_KEY=
COINDCX_API_SECRET=

# App Configuration
DEBUG=false
USD_INR_RATE=83.5
DEFAULT_MEMBER_ID=father

# Telegram digest (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email digest (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Database
DATABASE_URL=sqlite:///./wealthmap.db
